---
import {type Slug, SLUG_TO_TAG, TAG_TO_MULTIPLE} from "../server-util";
import { getAllPosts } from "@/server-util";
import Page from "./Page.astro";
import {Image} from "astro:assets";
import DateTime from "./DateTime.astro";

interface Props {
    onlyWithTag?: Slug
}

const maybeSlug = Astro.props.onlyWithTag;

const cas = maybeSlug
    ? TAG_TO_MULTIPLE[SLUG_TO_TAG[maybeSlug]]
    : "Explore";

const posts = await getAllPosts(
    !import.meta.env.DEV,
    maybeSlug && SLUG_TO_TAG[maybeSlug]
);

posts.sort((a, b) =>
    (a.data.pubUnix?.valueOf() || 0) - (b.data.pubUnix?.valueOf() || 0));
---

<Page title={cas} wide={true}>
    <h1 class="px-6 pt-12 font-bold text-3xl expanded">
        {cas}
    </h1>
    <div class="px-6 mt-6 grid gap-12 [grid-template-columns:repeat(auto-fit,minmax(256px,1fr))]">
        {posts.map(post => (
            <a href={`/${post.slug}/`} class="-m-3 block p-3 hover:bg-black/5 rounded-3xl transition active:bg-black/20">
                {post.data.hero && (
                    <Image
                        src={post.data.hero}
                        alt=""
                        widths={[400 / 4, 400 / 2, 400, 400 * 2]}
                        class={"rounded-2xl mb-3"}
                    />
                )}
                <div class="text-black/70">
                    {post.data.pubUnix && <DateTime date={post.data.pubUnix}/>}
                    {post.data.tags.map(tag => (
                        <span class="bg-black/10 px-2 rounded-full ml-2">{tag}</span>
                    ))}
                </div>
                <div class="text-2xl expanded font-semibold mt-2">
                    {post.data.title}
                </div>
            </a>
        ))}
        <div></div>
        <div></div>
        <div></div>
        <div></div>
    </div>
</Page>