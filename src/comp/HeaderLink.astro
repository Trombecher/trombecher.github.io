---
import type { HTMLAttributes } from 'astro/types'

interface Props extends HTMLAttributes<"a"> {}

const {class: className, ...props} = Astro.props;
---

<a {...props} class={`${Astro.url.pathname === props.href ? "font-bold" : "text-black/80"} ${className} hover:bg-black/5 active:bg-black/10 rounded-xl max-sm:rounded-2xl py-1 px-3 block`}>
    <slot/>
</a>