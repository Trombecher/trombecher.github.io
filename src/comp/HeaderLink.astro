---
import type { HTMLAttributes } from 'astro/types'

interface Props extends HTMLAttributes<"a"> {}

const {class: className, ...props} = Astro.props;
---

<a {...props} class={`${Astro.url.pathname === props.href ? "font-bold" : ""} ${className} hover:bg-blue/10 active:bg-blue/20 rounded-xl max-sm:rounded-2xl py-1 px-3 block`}>
    <slot/>
</a>